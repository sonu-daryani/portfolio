# =====================
# Ollama Cloud (chatbot)
# =====================
# Get your API key at https://ollama.com/account/keys
OLLAMA_USE_CLOUD=1
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_AGENT_MODEL=gpt-oss:120b

# =====================
# SMTP (contact form)
# =====================
# Used by /api/contact to send the recruiter notification + auto-reply.
# For Gmail, generate an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your.email@gmail.com
